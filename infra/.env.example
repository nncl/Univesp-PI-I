# --- Django ---
DJANGO_SECRET_KEY=please-change-me-to-a-long-random-string-min-50-chars
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Database (consumed by Django) ---
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_NAME=tattoo
DATABASE_USER=tattoo
DATABASE_PASSWORD=tattoopwd

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- MySQL container init (consumed by the db service) ---
MYSQL_ROOT_PASSWORD=rootpwd
MYSQL_DATABASE=tattoo
MYSQL_USER=tattoo
MYSQL_PASSWORD=tattoopwd

# --- Admin bootstrap (used by `create_admin` management command) ---
DJANGO_ADMIN_USERNAME=yara
DJANGO_ADMIN_PASSWORD=changeme
DJANGO_ADMIN_EMAIL=yara@example.com

# --- Frontend ---
# Used by the browser (must be reachable from the host)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
# Used by Next.js server components (reachable from inside the docker network)
INTERNAL_API_BASE_URL=http://backend:8000/api
